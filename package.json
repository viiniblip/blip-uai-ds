{
  "name": "blip-uai-ds",
  "version": "0.3.0",
  "description": "Make kit autocontido do UAI (blip-ds) para o Figma Make. Inclui blip-ds + blip-ds-react, registra os web components e provê o ThemeProvider + fonte.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" }
  },
  "files": ["dist", "guidelines"],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --declaration --declarationDir dist --outDir dist_tmp && rm -rf dist_tmp"
  },
  "dependencies": {
    "blip-ds": "2.0.0-rc.16",
    "blip-ds-react": "2.0.0-rc.16",
    "@fontsource/nunito-sans": "^5.0.0",
    "react-grid-system": "^8.2.0"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0"
  }
}
